PORT=5001
NODE_ENV=development
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/dream-signal?retryWrites=true&w=majority
JWT_SECRET=<your_jwt_secret_minimum_32_characters>
JWT_EXPIRES_IN=7d
AI_SERVICE_URL=http://localhost:8000

# ─────────────────────────────────────────────────────────────────────────────
# Optional: BullMQ + Redis for background dream processing.
# Leave REDIS_URL blank to keep the inline fallback (default).
# ─────────────────────────────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379
# DREAM_QUEUE_CONCURRENCY=2
# DREAM_QUEUE_ATTEMPTS=3

# ─────────────────────────────────────────────────────────────────────────────
# Optional: Sentry error reporting. Leave SENTRY_DSN blank to disable.
# ─────────────────────────────────────────────────────────────────────────────
# SENTRY_DSN=https://<key>@<project>.ingest.sentry.io/<id>
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_RELEASE=dreamsignal@1.0.0
