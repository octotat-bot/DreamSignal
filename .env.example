# Copy this to `.env` (same directory as docker-compose.yml) before
# running `docker compose up --build`. Values here are read by compose
# via ${VAR} interpolation in docker-compose.yml.

# Required ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=
JWT_SECRET=please_change_me_to_a_long_random_string

# Optional ─────────────────────────────────────────────────────────────
# Hugging Face token — raises the rate limit on the symbol classifier
# (BART-MNLI). Without it the AI service still works but logs
# "unauthenticated requests to the HF Hub" on startup.
HUGGINGFACE_API_KEY=

# Set to "true" to call Imagen and generate a dream-scene image per
# entry. Off by default to avoid burning quota during development.
IMAGEN_ENABLED=false
IMAGEN_MODEL=imagen-3.0-generate-002

# Faster-Whisper model size — tradeoff between accuracy and RAM.
#   tiny   ~ 39 MB  / fastest
#   base   ~ 74 MB  / default
#   small  ~ 244 MB
#   medium ~ 769 MB
WHISPER_MODEL=base
