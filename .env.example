# Copy this to `.env` (same directory as docker-compose.yml) before
# running `docker compose up --build`. Values here are read by compose
# via ${VAR} interpolation in docker-compose.yml.

# Required ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=
JWT_SECRET=please_change_me_to_a_long_random_string

# Optional ─────────────────────────────────────────────────────────────
# Hugging Face token — silences the "unauthenticated requests to the
# HF Hub" startup warning on sentence-transformer downloads.
# (Symbol + emotion classification both run locally now and don't need
# the HF Inference API.)
HUGGINGFACE_API_KEY=

# Faster-Whisper model size — tradeoff between accuracy and RAM.
#   tiny   ~ 39 MB  / fastest
#   base   ~ 74 MB  / default
#   small  ~ 244 MB
#   medium ~ 769 MB
WHISPER_MODEL=base

# Dream-processing queue — BullMQ + Redis.
# Leave commented out to fall back to inline (fire-and-forget) processing,
# which is the legacy behavior. When set, dream submissions are queued
# and processed with retries + exponential backoff.
# REDIS_URL=redis://redis:6379
# DREAM_QUEUE_CONCURRENCY=2
# DREAM_QUEUE_ATTEMPTS=3
