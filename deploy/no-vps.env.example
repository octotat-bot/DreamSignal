# Environment variables for NO-VPS deploy (Render + Vercel + Atlas).
# Copy values into each platform's dashboard — do not commit secrets.

# ═══════════════════════════════════════════════════════════════════════
# 1. MongoDB Atlas  (https://cloud.mongodb.com)
# ═══════════════════════════════════════════════════════════════════════
# Create a free M0 cluster → Database Access user → Network Access:
#   add 0.0.0.0/0 (allows Render's dynamic IPs) or Render's IP ranges.
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/dream-signal

# ═══════════════════════════════════════════════════════════════════════
# 2. Render — dreamsignal-ai service
# ═══════════════════════════════════════════════════════════════════════
GEMINI_API_KEY=
HUGGINGFACE_API_KEY=          # optional
WHISPER_MODEL_SIZE=base        # use "tiny" if Starter plan runs out of RAM

# ═══════════════════════════════════════════════════════════════════════
# 3. Render — dreamsignal-api service
#    (JWT_SECRET is auto-generated by render.yaml)
# ═══════════════════════════════════════════════════════════════════════
# AI_SERVICE_URL is wired automatically from the AI service URL.
FRONTEND_URL=https://YOUR-APP.vercel.app
SENTRY_DSN=                    # optional

# ═══════════════════════════════════════════════════════════════════════
# 4. Vercel — frontend project  (Root Directory = frontend)
# ═══════════════════════════════════════════════════════════════════════
VITE_API_BASE_URL=https://dreamsignal-api.onrender.com/api
# Replace with your actual Render API URL after first deploy.

# Optional Sentry (frontend):
# VITE_SENTRY_DSN=
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
