# Copy to the repo root as `.env.production` before deploying:
#   cp deploy/.env.production.example .env.production
#
# Then run:  bash scripts/deploy-prod.sh

# ── Required ──────────────────────────────────────────────────────────
# Your public domain (must point to the server's IP before first deploy).
DOMAIN=yourdomain.com
ACME_EMAIL=you@yourdomain.com

# MongoDB Atlas connection string (Network Access must allow this server's IP).
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/dream-signal?retryWrites=true&w=majority

# Any random string, 32+ characters.
JWT_SECRET=replace_with_a_long_random_secret_string

# Google Gemini — required for dream interpretation.
GEMINI_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────
HUGGINGFACE_API_KEY=
SENTRY_DSN=

# Faster-Whisper size: tiny | base (default) | small | medium
# base needs ~2 GB RAM for the AI container; medium needs ~4 GB+.
WHISPER_MODEL=base

CLEANUP_INTERVAL_HOURS=24
CLEANUP_MAX_AGE_DAYS=7
CLEANUP_DRY_RUN=false
