# Auto-TLS reverse proxy. DOMAIN and ACME_EMAIL are injected by compose.
#
#   https://yourdomain.com  →  frontend nginx (SPA + /api proxy)
#
# For local testing without a domain, use docker-compose.yml instead.

{$DOMAIN} {
	email {$ACME_EMAIL}
	encode gzip

	# Everything hits the frontend nginx, which proxies /api and /storage
	# to the backend on the internal Docker network.
	reverse_proxy frontend:80
}
