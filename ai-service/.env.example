# ─────────────────────────────────────────────────────────────────────────────
# AI service runtime
# ─────────────────────────────────────────────────────────────────────────────
PORT=8000
HOST=127.0.0.1

# ─────────────────────────────────────────────────────────────────────────────
# Required
# ─────────────────────────────────────────────────────────────────────────────
# Google Gemini API key (https://aistudio.google.com/apikey)
# Used for: dream interpretation (gemini-2.5-flash). Free tier is fine.
GEMINI_API_KEY=<your_gemini_api_key>

# ─────────────────────────────────────────────────────────────────────────────
# Optional — only needed for authenticated HF model downloads (silences the
# "you are sending unauthenticated requests" warning, doesn't change behaviour)
# ─────────────────────────────────────────────────────────────────────────────
# HUGGINGFACE_API_KEY=<your_hf_token>

# ─────────────────────────────────────────────────────────────────────────────
# Local model knobs
# ─────────────────────────────────────────────────────────────────────────────
# Whisper transcription model: tiny | base | small | medium | large
WHISPER_MODEL_SIZE=base
# Sentence-transformer used for both embeddings and the in-process zero-shot
# emotion + symbol classifiers (HF Inference API was retired in 2024).
EMBEDDING_MODEL=all-MiniLM-L6-v2
# EMBEDDING_CACHE_SIZE=512
# EMOTION_SOFTMAX_TEMP=0.18
# SYMBOL_SCORE_THRESHOLD=0.18
# SYMBOL_TOP_K=5
# SYMBOL_LABELS=water,fire,door,...   # comma-separated, overrides defaults
